{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.tradecoffeeco.com/*",
    "https://tradecoffeeco.com/*",
    "https://www.bluebottlecoffee.com/*",
    "https://bluebottlecoffee.com/*",
    "https://www.onyxcoffeelab.com/*",
    "https://onyxcoffeelab.com/*",
    "https://www.counterculturecoffee.com/*",
    "https://counterculturecoffee.com/*",
    "https://www.intelligentsiacoffee.com/*",
    "https://intelligentsiacoffee.com/*",
    "https://www.stumptowncoffee.com/*",
    "https://stumptowncoffee.com/*",
    "https://www.atlascoffeeclub.com/*",
    "https://atlascoffeeclub.com/*",
    "https://www.beanbox.com/*",
    "https://beanbox.com/*",
    "https://www.vervecoffee.com/*",
    "https://vervecoffee.com/*",
    "https://www.chromecoffee.com/*",
    "https://chromecoffee.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tradecoffeeco.com/*",
        "https://tradecoffeeco.com/*",
        "https://www.bluebottlecoffee.com/*",
        "https://bluebottlecoffee.com/*",
        "https://www.onyxcoffeelab.com/*",
        "https://onyxcoffeelab.com/*",
        "https://www.counterculturecoffee.com/*",
        "https://counterculturecoffee.com/*",
        "https://www.intelligentsiacoffee.com/*",
        "https://intelligentsiacoffee.com/*",
        "https://www.stumptowncoffee.com/*",
        "https://stumptowncoffee.com/*",
        "https://www.atlascoffeeclub.com/*",
        "https://atlascoffeeclub.com/*",
        "https://www.beanbox.com/*",
        "https://beanbox.com/*",
        "https://www.vervecoffee.com/*",
        "https://vervecoffee.com/*",
        "https://www.chromecoffee.com/*",
        "https://chromecoffee.com/*"
      ],
      "js": ["content/coffee-detector.js", "content/coffee-badge.js"],
      "css": ["content/coffee-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "default_locale": "en",
  "web_accessible_resources": [
    {
      "resources": [
        "data/roastery-config.json"
      ],
      "matches": [
        "https://www.tradecoffeeco.com/*",
        "https://tradecoffeeco.com/*",
        "https://www.bluebottlecoffee.com/*",
        "https://bluebottlecoffee.com/*",
        "https://www.onyxcoffeelab.com/*",
        "https://onyxcoffeelab.com/*",
        "https://www.counterculturecoffee.com/*",
        "https://counterculturecoffee.com/*",
        "https://www.intelligentsiacoffee.com/*",
        "https://intelligentsiacoffee.com/*",
        "https://www.stumptowncoffee.com/*",
        "https://stumptowncoffee.com/*",
        "https://www.atlascoffeeclub.com/*",
        "https://atlascoffeeclub.com/*",
        "https://www.beanbox.com/*",
        "https://beanbox.com/*",
        "https://www.vervecoffee.com/*",
        "https://vervecoffee.com/*",
        "https://www.chromecoffee.com/*",
        "https://chromecoffee.com/*"
      ]
    }
  ]
}
