{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.burpee.com/*",
    "https://burpee.com/*",
    "https://www.rareseeds.com/*",
    "https://rareseeds.com/*",
    "https://www.johnnyseeds.com/*",
    "https://johnnyseeds.com/*",
    "https://www.parkseed.com/*",
    "https://parkseed.com/*",
    "https://www.territorialseed.com/*",
    "https://territorialseed.com/*",
    "https://www.westcoastseeds.com/*",
    "https://westcoastseeds.com/*",
    "https://www.migardener.com/*",
    "https://migardener.com/*",
    "https://www.seedsavers.org/*",
    "https://seedsavers.org/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.burpee.com/*",
        "https://burpee.com/*",
        "https://www.rareseeds.com/*",
        "https://rareseeds.com/*",
        "https://www.johnnyseeds.com/*",
        "https://johnnyseeds.com/*",
        "https://www.parkseed.com/*",
        "https://parkseed.com/*",
        "https://www.territorialseed.com/*",
        "https://territorialseed.com/*",
        "https://www.westcoastseeds.com/*",
        "https://westcoastseeds.com/*",
        "https://www.migardener.com/*",
        "https://migardener.com/*",
        "https://www.seedsavers.org/*",
        "https://seedsavers.org/*"
      ],
      "js": ["content/seed-detector.js", "content/planting-badge.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "default_locale": "en",
  "web_accessible_resources": [
    {
      "resources": [
        "data/zip-zones.json",
        "data/crop-keywords.json",
        "data/planting-guide.json",
        "data/companions.json"
      ],
      "matches": [
        "https://www.burpee.com/*",
        "https://burpee.com/*",
        "https://www.rareseeds.com/*",
        "https://rareseeds.com/*",
        "https://www.johnnyseeds.com/*",
        "https://johnnyseeds.com/*",
        "https://www.parkseed.com/*",
        "https://parkseed.com/*",
        "https://www.territorialseed.com/*",
        "https://territorialseed.com/*",
        "https://www.westcoastseeds.com/*",
        "https://westcoastseeds.com/*",
        "https://www.migardener.com/*",
        "https://migardener.com/*",
        "https://www.seedsavers.org/*",
        "https://seedsavers.org/*"
      ]
    }
  ]
}
