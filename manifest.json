{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.fidelity.com/*",
    "https://fidelity.com/*",
    "https://*.vanguard.com/*",
    "https://vanguard.com/*",
    "https://*.schwab.com/*",
    "https://schwab.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.fidelity.com/*",
        "https://*.vanguard.com/*",
        "https://*.schwab.com/*"
      ],
      "js": ["content/balance-detector.js", "content/fire-sidebar.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "default_locale": "en",
  "web_accessible_resources": []
}
