{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://www.fiverr.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/jobs/*",
        "https://www.upwork.com/ab/proposals/*",
        "https://www.upwork.com/nx/jobs/*"
      ],
      "js": ["content/upwork-extractor.js", "content/panel-injector.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.fiverr.com/requests/*",
        "https://www.fiverr.com/inbox/*"
      ],
      "js": ["content/fiverr-extractor.js", "content/panel-injector.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "default_locale": "en",
  "web_accessible_resources": [
    {
      "resources": ["content/panel.html"],
      "matches": [
        "https://www.upwork.com/*",
        "https://www.fiverr.com/*"
      ]
    }
  ]
}
