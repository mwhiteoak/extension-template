{
  "manifest_version": 3,
  "name": "Tank Scout — Fish Compatibility Checker",
  "short_name": "Tank Scout",
  "version": "1.0.0",
  "description": "Instantly check aquarium fish compatibility on LiveAquaria, Aquabid & eBay. Powered by FishBase and Seriously Fish.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.liveaquaria.com/*",
    "https://www.aquabid.com/*",
    "https://www.ebay.com/*",
    "https://www.seriouslyfish.com/*",
    "https://www.fishbase.org/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.liveaquaria.com/*",
        "https://www.aquabid.com/*",
        "https://www.ebay.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tank Scout",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/species.json"],
      "matches": [
        "https://www.liveaquaria.com/*",
        "https://www.aquabid.com/*",
        "https://www.ebay.com/*"
      ]
    }
  ]
}
