{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://amazon.com/*",
    "https://www.target.com/*",
    "https://target.com/*",
    "https://www.walmart.com/*",
    "https://walmart.com/*",
    "https://www.miniaturemarket.com/*",
    "https://miniaturemarket.com/*",
    "https://www.coolstuffinc.com/*",
    "https://coolstuffinc.com/*",
    "https://www.gamenerdz.com/*",
    "https://gamenerdz.com/*",
    "https://www.funagain.com/*",
    "https://funagain.com/*",
    "https://boardgamegeek.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://amazon.com/*",
        "https://www.target.com/*",
        "https://target.com/*",
        "https://www.walmart.com/*",
        "https://walmart.com/*",
        "https://www.miniaturemarket.com/*",
        "https://miniaturemarket.com/*",
        "https://www.coolstuffinc.com/*",
        "https://coolstuffinc.com/*",
        "https://www.gamenerdz.com/*",
        "https://gamenerdz.com/*",
        "https://www.funagain.com/*",
        "https://funagain.com/*"
      ],
      "js": ["content/game-detector.js", "content/bgg-panel.js"],
      "css": ["content/bgg-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "default_locale": "en",
  "web_accessible_resources": []
}
